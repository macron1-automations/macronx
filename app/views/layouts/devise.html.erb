<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Macron X" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Macron X</h1>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <% if notice.present? %>
          <p class="mb-6 text-sm text-green-700 bg-green-50 rounded-lg px-4 py-3"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="mb-6 text-sm text-red-700 bg-red-50 rounded-lg px-4 py-3"><%= alert %></p>
        <% end %>

        <%= yield %>
      </div>
    </div>
  </body>
</html>
