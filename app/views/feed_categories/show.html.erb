<div class="mb-6 flex items-start justify-between">
  <div>
    <%= link_to '&larr; Feed Categories'.html_safe, feed_categories_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
    <h1 class="mt-3 text-2xl font-semibold text-gray-900"><%= @feed_category.name %></h1>
    <p class="mt-1 text-sm text-gray-500">Created <%= @feed_category.created_at.strftime('%B %d, %Y') %></p>
  </div>
  <div class="flex items-center gap-x-2">
    <%= link_to 'Edit', edit_feed_category_path(@feed_category),
          class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors duration-150" %>
    <%= button_to 'Delete', @feed_category, method: :delete,
          data: { turbo_confirm: "Delete \"#{@feed_category.name}\"? This cannot be undone." },
          class: "inline-flex items-center rounded-md border border-red-300 bg-white px-3 py-2 text-sm font-medium text-red-600 shadow-sm hover:bg-red-50 transition-colors duration-150" %>
  </div>
</div>

<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
  <h2 class="mb-4 text-base font-medium text-gray-900">
    Feeds
    <span class="ml-2 inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700"><%= @feeds.size %></span>
  </h2>
  <% if @feeds.any? %>
    <ul class="divide-y divide-gray-100">
      <% @feeds.each do |feed| %>
        <li class="flex items-center justify-between py-3">
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-900"><%= feed.title %></p>
            <p class="truncate text-xs text-gray-500"><%= feed.feed_url %></p>
          </div>
          <%= link_to 'View', feed, class: "text-sm text-indigo-600 hover:text-indigo-900 transition-colors duration-150" %>
        </li>
      <% end %>
    </ul>
    <p class="mt-4 text-xs text-gray-500">Reassign or delete these feeds before deleting this category.</p>
  <% else %>
    <p class="text-sm text-gray-500">No feeds are assigned to this category.</p>
  <% end %>
</div>
