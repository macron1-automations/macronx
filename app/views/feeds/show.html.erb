<div data-controller="keyboard-shortcuts">
<%= render 'shared/keyboard_shortcut_help',
      title: 'Feed view',
      shortcuts: [
        { label: 'Back to Feeds', key: 'u' },
        { label: 'Edit feed', key: 'e' },
        { label: 'Delete feed', key: 'd' }
      ] %>

<div class="mb-6 flex items-start justify-between">
  <div>
    <div class="flex items-center gap-x-3">
      <%= link_to feeds_path,
            title: "Back to Feeds (u)",
            data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "u" },
            class: "inline-flex items-center gap-x-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors duration-150" do %>
        &larr; Feeds
        <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-400">u</kbd>
      <% end %>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @feed.title %></h1>
    </div>
    <p class="mt-1 text-sm text-gray-500">Created <%= @feed.created_at.strftime('%B %d, %Y') %></p>
  </div>
  <div class="flex items-center gap-x-2">
    <%= link_to edit_feed_path(@feed),
          title: "Edit feed (e)",
          data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "e" },
          class: "inline-flex items-center gap-x-1.5 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors duration-150" do %>
      Edit
      <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">e</kbd>
    <% end %>
    <%= button_to @feed, method: :delete,
          data: {
            turbo_confirm: "Delete \"#{@feed.title}\"? This cannot be undone.",
            keyboard_shortcuts_target: "trigger",
            keyboard_shortcuts_key: "d"
          },
          title: "Delete feed (d)",
          class: "inline-flex items-center gap-x-1.5 rounded-md border border-red-300 bg-white px-3 py-2 text-sm font-medium text-red-600 shadow-sm hover:bg-red-50 transition-colors duration-150" do %>
      Delete
      <kbd class="rounded border border-red-200 bg-red-50 px-1 py-0.5 font-mono text-xs font-normal text-red-500">d</kbd>
    <% end %>
    <button type="button"
            title="Keyboard shortcuts (?)"
            data-action="click->keyboard-shortcuts#toggleHelp"
            class="inline-flex items-center rounded-md border border-gray-300 bg-white px-2 py-2 text-sm text-gray-500 shadow-sm hover:bg-gray-50 hover:text-gray-700 transition-colors duration-150 cursor-pointer">
      <span class="inline-flex h-4 w-4 items-center justify-center font-semibold">?</span>
    </button>
  </div>
</div>
</div>

<div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
  <div class="border-b border-gray-100 bg-gray-50 px-6 py-3">
    <h2 class="text-sm font-semibold text-gray-700">Details</h2>
  </div>
  <dl class="divide-y divide-gray-100">
    <div class="grid grid-cols-3 gap-4 px-6 py-4">
      <dt class="text-sm font-medium text-gray-500">Title</dt>
      <dd class="col-span-2 text-sm text-gray-900"><%= @feed.title %></dd>
    </div>
    <div class="grid grid-cols-3 gap-4 px-6 py-4">
      <dt class="text-sm font-medium text-gray-500">Category</dt>
      <dd class="col-span-2 text-sm text-gray-900"><%= link_to @feed.feed_category.name, @feed.feed_category, class: "text-indigo-600 hover:text-indigo-900" %></dd>
    </div>
    <div class="grid grid-cols-3 gap-4 px-6 py-4">
      <dt class="text-sm font-medium text-gray-500">Feed URL</dt>
      <dd class="col-span-2 break-all text-sm text-gray-900"><%= @feed.feed_url %></dd>
    </div>
    <div class="grid grid-cols-3 gap-4 px-6 py-4">
      <dt class="text-sm font-medium text-gray-500">Updated</dt>
      <dd class="col-span-2 text-sm text-gray-900"><%= @feed.updated_at.strftime('%B %d, %Y at %H:%M UTC') %></dd>
    </div>
  </dl>
</div>
